{
	"name": "envelector",
	"version": "0.0.1",
	"description": "Local developer tool for managing .env files — scan, compare, and apply values across environments from a browser UI.",
	"type": "module",
	"bin": {
		"envelector": "bin/envelector.js"
	},
	"files": [
		"bin",
		"build",
		"LICENSE"
	],
	"keywords": [
		"env",
		"dotenv",
		"environment",
		"cli",
		"developer-tools",
		"svelte",
		"sveltekit"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "node -e \"require('fs').existsSync('src') && require('child_process').execSync('svelte-kit sync', {stdio:'inherit'})\" || true",
		"prepublishOnly": "node -e \"require('fs').rmSync('build', {recursive:true,force:true})\" && pnpm build",
		"prepack": "node -e \"const g=require('fs').globSync('build/**/*.map');g.forEach(f=>require('fs').rmSync(f))\"",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"svelte-sonner": "^1.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {}
}
