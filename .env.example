# ─────────────────────────────────────────────
# ENV FILE SYSTEM
# .env.example    — canonical reference of ALL possible keys (placeholder values)
#                   Every key the app may read must be listed here.
# .env.staging    — fully configured values for the staging environment
# .env.production — fully configured values for the production environment
# .env.dev        — fully configured values for the development environment
# .env            — the file actually loaded at runtime / local dev.
#                   Copy the relevant .env.<environment> file here, or maintain
#                   it manually for local overrides (e.g. CRM tunnel config).
# ─────────────────────────────────────────────
#
# ─────────────────────────────────────────────
# ENVELECTOR GROUPING
# Envelector reads this file to automatically group keys in the UI.
#
# How it works:
#   Add a "# GROUP: <name>" comment before any set of keys.
#   All KEY= lines that follow (until the next GROUP marker) are
#   placed under that group in the editor.
#
# Example:
#   # GROUP: DATABASE
#   DB_HOST=localhost
#   DB_PORT=5432
#   DB_PASSWORD=secret
#
# Rules:
#   - Group names can contain letters, numbers, hyphens, and spaces.
#   - Commented-out keys (# KEY=...) are ignored — only active keys count.
#   - Keys not preceded by any GROUP marker appear ungrouped at the top.
#   - This file is never written to by Envelector; edit it manually.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# GROUP: SUPABASE
# Get values from: https://app.supabase.com/project/_/settings/api
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# GROUP: CAPIBOX
# Subscription / payment data
# ─────────────────────────────────────────────
CAPIBOX_API_KEY=your-capibox-api-key
# Set to true to log raw Capibox API responses
DEBUG_CAPIBOX=false

# ─────────────────────────────────────────────
# GROUP: CRM
# Optional — order item SKU lookup
# Requires Tailscale tunnel for remote access
# ─────────────────────────────────────────────
CRM_DB_HOST=your-db-host.db.ondigitalocean.com
CRM_DB_PORT=25060
CRM_DB_USER=your-db-user
CRM_DB_PASSWORD=your-db-password

# ─────────────────────────────────────────────
# GROUP: INNGEST
# Background jobs
# Get keys from: https://app.inngest.com → Your App → Settings → Keys
# For LOCAL DEV: leave INNGEST_EVENT_KEY empty so events go to local dev server
# ─────────────────────────────────────────────
#INNGEST_APP_URL=https://admin.tinysnap.com
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=signkey-prod-your-signing-key

# ─────────────────────────────────────────────
# GROUP: ROBOT-TESTER
# Automated admin testing
# ─────────────────────────────────────────────
ROBOT_TESTER_EMAIL=robot-the-tester@mytinysnap.com
ROBOT_TESTER_API_KEY=your-robot-tester-api-key

# ─────────────────────────────────────────────
# GROUP: KLAVIYO
# Email / CRM
# ─────────────────────────────────────────────
KLAVIYO_PRIVATE_API_KEY=pk_your-klaviyo-key

# ─────────────────────────────────────────────
# GROUP: PRINTIFY
# Print-on-demand
# ─────────────────────────────────────────────
PRINTIFY_SHOP_ID=your-shop-id
PRINTIFY_API_KEY=your-printify-jwt-token
PRINTIFY_WEBHOOK_SECRET=your-webhook-secret
PRINT_APP_URL=https://prints.tinysnap.com
# Shared secret for print sync API — must match PRINT_SYNC_SECRET in print app
PRINT_SYNC_SECRET=your-print-sync-secret

# ─────────────────────────────────────────────
# GROUP: APP-URLS
# Application URLs
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tinysnap.com
NEXT_PUBLIC_MVP_URL=https://app.tinysnap.com
NEXT_PUBLIC_ADMIN_URL=https://admin.tinysnap.com

# ─────────────────────────────────────────────
# GROUP: PRICING
# Cross-app pricing consistency
# Shared secret for GET /api/pricing — same key in funnels, product, print
# ─────────────────────────────────────────────
PRICING_API_KEY=your-pricing-api-key
# Funnels app URL — product uses NEXT_PUBLIC_MVP_URL, print uses PRINT_APP_URL
FUNNELS_URL=https://tinysnap.com

# ─────────────────────────────────────────────
# GROUP: AXIOM
# Structured logging
# Create a dataset and API token at https://app.axiom.co
# ─────────────────────────────────────────────
AXIOM_DATASET=tinysnap-production-combined
AXIOM_TOKEN=xaat-your-axiom-token

# ─────────────────────────────────────────────
# GROUP: META
# Meta Marketing API — ad spend / analytics
# Shared token covering all TinySnap ad accounts
# Get from: Meta Business Manager → System Users → Generate Token
# ─────────────────────────────────────────────
META_ACCESS_TOKEN=your-meta-access-token
# Ad account IDs (without the "act_" prefix)
META_AD_ACCOUNT_ID_PRODUCT=your-product-ad-account-id
META_AD_ACCOUNT_ID_PRINTS=your-prints-ad-account-id

# ─────────────────────────────────────────────
# GROUP: DO-SPACES
# DigitalOcean Spaces — image storage, same account as apps/product
# Get from: DigitalOcean → Spaces → Manage Keys
# ─────────────────────────────────────────────
DO_SPACES_KEY=your-do-spaces-key
DO_SPACES_SECRET=your-do-spaces-secret
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_CDN_ENDPOINT=https://nyc3.cdn.digitaloceanspaces.com
